{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm run install:all",
  "rewrites": [
    { "source": "/:locale(ro|ru|es|de)/catalogue/:slug", "destination": "/catalogue/product/index.html" },
    { "source": "/catalogue/:slug", "destination": "/catalogue/product/index.html" },
    { "source": "/:locale(ro|ru|es|de)/merch/:slug", "destination": "/merch/product/index.html" },
    { "source": "/merch/:slug", "destination": "/merch/product/index.html" },
    { "source": "/:locale(ro|ru|es|de)/catalogue", "destination": "/catalogue/index.html" },
    { "source": "/:locale(ro|ru|es|de)/merch", "destination": "/merch/index.html" },
    { "source": "/:locale(ro|ru|es|de)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/en", "destination": "/", "permanent": true },
    { "source": "/en/", "destination": "/", "permanent": true },
    { "source": "/en/catalogue", "destination": "/catalogue", "permanent": true },
    { "source": "/en/catalogue/", "destination": "/catalogue", "permanent": true },
    { "source": "/en/merch", "destination": "/merch", "permanent": true },
    { "source": "/en/merch/", "destination": "/merch", "permanent": true }
  ]
}
